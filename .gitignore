# Large files (use Git LFS instead)
# Audio files are ignored everywhere EXCEPT in clips/ folder
# clips/ folder audio goes to Hugging Face via Git LFS
*.wav
*.mp3
*.flac
*.ogg
*.m4a

# Allow audio files in clips/ folder (for Hugging Face LFS)
!clips/**/*.wav
!clips/**/*.mp3
!clips/**/*.flac

# OCR models (download separately: brew install tesseract)
tessdata/

# Auto-generated backups (notebook safety copies)
backups/

# Test output (generated by notebook Section 18 in test mode)
test_splits/

# Trained models (too large for git)
models/

